# Application
APP_NAME="Backend API"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Admin
ADMIN_TOKEN=change-this-admin-token
PRODUCTION=false
DB_PROD_URL=postgresql://user:password@host:5432/dbname

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=postgres

# Frontend (for CORS and email links)
FRONTEND_URL=http://localhost:3000
