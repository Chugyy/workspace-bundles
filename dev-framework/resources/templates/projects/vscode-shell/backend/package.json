{
  "name": "shell-backend",
  "version": "1.0.0",
  "description": "SSH Web IDE backend - Fastify proxy for SSH/SFTP connections",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --external dotenv",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/websocket": "^11.0.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.3.2",
    "openai": "^6.31.0",
    "ssh2": "^1.16.0",
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ssh2": "^1.15.4",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
