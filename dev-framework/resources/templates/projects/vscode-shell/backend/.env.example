PORT=3001
HOST=0.0.0.0

# Auth
AUTH_PASSWORD=changeme
SESSION_SECRET=generate-a-random-32-char-string-here

# SSH target (use host.docker.internal to reach the VPS host from inside Docker)
SSH_HOST=host.docker.internal
SSH_PORT=22
SSH_USERNAME=root
SSH_PRIVATE_KEY_PATH=/root/.ssh/id_rsa
# SSH_PASSWORD=  # alternative to key-based auth

# SFTP root accessible to the frontend file explorer
SFTP_ROOT_PATH=/root/personal-claude-code-agent

# CORS: must match the public URL of the frontend
CORS_ORIGIN=http://localhost:3100

# Terminal
TERMINAL_TIMEOUT=7200000
TERMINAL_WARNING_BEFORE=300000

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
