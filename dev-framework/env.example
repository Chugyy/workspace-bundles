# === Anthropic ===
# Required for Claude Code agents
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# === GitHub (GHCR) ===
# Used by /deploy skill to push Docker images
# Get from: https://github.com/settings/tokens → Generate new token (classic) → scopes: write:packages
GHCR_REGISTRY_URL=ghcr.io
GHCR_USERNAME=your-github-username
GHCR_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Dokploy (optional) ===
# Cloud deployment platform
# Get from: https://app.dokploy.com → Settings → API
DOKPLOY_URL=https://app.dokploy.com/api
DOKPLOY_API_KEY=your-dokploy-api-key

# === Hostinger (optional) ===
# Domain/DNS management
# Get from: https://hpanel.hostinger.com → Account → API
HOSTINGER_API_KEY=your-hostinger-api-key

# === SSH VPS (optional) ===
# For remote server access via MCP
SSH_VPS_HOST=your-server-ip
SSH_VPS_USERNAME=root
SSH_VPS_KEY_PATH=/path/to/.ssh/id_ed25519
