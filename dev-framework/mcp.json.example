{
  "mcpServers": {
    "origin-ui": {
      "type": "stdio",
      "command": "npx",
      "args": ["--yes", "github:kelvinchng/origin-ui-mcp"],
      "env": {}
    },
    "shadcn": {
      "type": "http",
      "url": "https://www.shadcn.io/api/mcp"
    },
    "icons8mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["mcp-remote", "https://mcp.icons8.com/mcp/"],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["--yes", "@playwright/mcp@latest"]
    },
    "ssh-mcp-personal-vps": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@fangjunjie/ssh-mcp-server",
        "--host", "{{VPS_HOST}}",
        "--port", "22",
        "--username", "{{VPS_USERNAME}}",
        "--privateKey", "{{SSH_KEY_PATH}}",
        "--passphrase", "{{SSH_PASSPHRASE}}"
      ]
    },
    "dokploy": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@ahdev/dokploy-mcp"],
      "env": {
        "DOKPLOY_URL": "{{DOKPLOY_URL}}",
        "DOKPLOY_API_KEY": "{{DOKPLOY_API_KEY}}"
      }
    },
    "hostinger": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "hostinger-api-mcp@latest"],
      "env": {
        "API_TOKEN": "{{HOSTINGER_API_KEY}}"
      }
    }
  }
}
